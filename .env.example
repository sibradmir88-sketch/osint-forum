# ─── Обязательно ───────────────────────────────────────
SESSION_SECRET=замени_на_случайную_строку_минимум_32_символа
BASE_URL=https://твой-проект.railway.app

# ─── Railway Volume (персистентность БД) ───────────────
# В Railway создай Volume с mount path = /data
# Тогда forum.db будет храниться на volume и не сбросится при редеплое

# ─── Порт ──────────────────────────────────────────────
PORT=3000

# ─── Google Drive backup (опционально) ─────────────────
# На локальной машине (не на Railway) раз в день делай:
#   bash backup-db.sh
# Авто-бэкап внутри Railway контейнера НЕ работает без rclone конфига.
# Для восстановления после сбоя используй Volume в Railway.
